# Supabase — find these in your project's API settings:
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Base URL of the deployed app (used for OAuth redirects).
# Local dev can leave this as-is; set to your Vercel URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: enables Claude-powered synthesis ("Enhance with AI").
# Get a key at https://console.anthropic.com/ . If unset, JobWize falls back
# to its built-in template synthesis. Override the model with ANTHROPIC_MODEL.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
