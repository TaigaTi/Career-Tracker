# Supabase — find these in your project's API settings:
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Base URL of the deployed app (used for OAuth redirects).
# Local dev can leave this as-is; set to your Vercel URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: enables AI-powered synthesis ("Enhance with AI").
# Set EITHER provider key. Gemini takes priority when both are set.
# If neither is set, JobWize falls back to its built-in template synthesis.

# Google AI Studio (Gemini) — free tier available: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
